DEEPSEEK_API_KEY=sk-your-deepseek-api-key
BRAVE_API_KEY=your-brave-api-key
ECOSYSTEM_DIR=./ecosystem
CYCLE_INTERVAL_MS=14400000
DEFAULT_TOKEN=1000000
MAX_AGENTS=20
ELIMINATION_RATE=0.3
MUTATION_RATE=0.1
NEW_AGENT_PROTECTION=3
DASHBOARD_PORT=3000
SMTP_HOST=smtp.163.com
SMTP_PORT=465
EMAIL_USER=your-email@163.com
EMAIL_PASS=your-base64-encoded-password
NOTIFY_EMAIL=your-personal@example.com
POP3_HOST=pop.163.com
POP3_PORT=995
# Bounty shell_test sandbox. shell_test is DISABLED unless this is set.
# Whitespace-split into argv prefix; the agent command runs as `sh -c <command>`
# with this prefix in front. Recommended on Linux:
#   BOUNTY_SHELL_SANDBOX_CMD=bwrap --ro-bind / / --tmpfs /tmp --unshare-net --unshare-pid --die-with-parent --
# BOUNTY_SHELL_SANDBOX_CMD=
